# RepoGuide — Environment Variables
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# Required: Your Anthropic API key for Claude
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional but recommended: GitHub personal access token
# Without this, you're limited to 60 GitHub API requests/hour
# With it, you get 5,000 requests/hour
# Create one at https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
